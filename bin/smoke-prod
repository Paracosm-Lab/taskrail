#!/usr/bin/env bash
set -euo pipefail

BASE_URL="${BASE_URL:-${STUPIDCLAW_BASE_URL:-}}"
TOKEN="${STUPIDCLAW_SERVICE_TOKEN:-}"
if [ -z "${BASE_URL}" ]; then
  echo "usage: BASE_URL=https://service.example.com bin/smoke-prod" >&2
  exit 1
fi

curl -fsS "${BASE_URL}/health" >/dev/null

if [ -n "${TOKEN}" ]; then
  curl -fsS -H "Authorization: Bearer ${TOKEN}" "${BASE_URL}/api/v1/queues" >/dev/null
else
  curl -fsS "${BASE_URL}/api/v1/queues" >/dev/null
fi

echo "smoke-prod passed"

#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "optparse"
require_relative "../app/services/cli/stupid_claw_api_client"
require_relative "../app/services/cli/dashboard_data_loader"
require_relative "../app/services/cli/dashboard_renderer"

class StupidClawCli
  def initialize(argv, env = ENV, stdout = $stdout, stderr = $stderr)
    @argv = argv
    @env = env
    @base_url = env.fetch("STUPIDCLAW_API_URL", "http://localhost:3000")
    @stdout = stdout
    @stderr = stderr
    @client = Cli::StupidClawApiClient.new(base_url: @base_url)
  end

  def run
    command = @argv.shift

    case command
    when "submit" then submit
    when "status" then status
    when "list" then list
    when "answer" then answer
    when "retry" then post("/api/v1/work_items/#{required_arg("WORK_ITEM_ID")}/retry", {})
    when "cancel" then post("/api/v1/work_items/#{required_arg("WORK_ITEM_ID")}/cancel", {})
    when "queues" then get("/api/v1/queues")
    when "stages" then get("/api/v1/queues/#{required_arg("QUEUE")}/stages")
    when "dashboard" then dashboard
    when "costs" then costs
    else
      @stderr.puts "unknown command: #{command}"
      return 1
    end

    0
  rescue KeyError, ArgumentError, Cli::StupidClawApiClient::HttpError => error
    @stderr.puts error.message
    1
  end

  private

  def submit
    options = {}
    OptionParser.new do |parser|
      parser.on("--queue QUEUE") { |value| options[:queue] = value }
      parser.on("--spec SPEC") { |value| options[:spec_url] = value }
      parser.on("--title TITLE") { |value| options[:title] = value }
    end.parse!(@argv)

    post("/api/v1/work_items", {
      queue: options.fetch(:queue),
      spec_url: options.fetch(:spec_url),
      title: options.fetch(:title)
    })
  end

  def status
    id = URI.encode_www_form_component(required_arg("WORK_ITEM_ID"))
    options = {}
    OptionParser.new do |parser|
      parser.on("--traces") { options[:traces] = true }
    end.parse!(@argv)

    query = URI.encode_www_form(options)
    get(query.empty? ? "/api/v1/work_items/#{id}" : "/api/v1/work_items/#{id}?#{query}")
  end

  def list
    options = {}
    OptionParser.new do |parser|
      parser.on("--queue QUEUE") { |value| options[:queue] = value }
      parser.on("--stage STAGE") { |value| options[:stage] = value }
    end.parse!(@argv)

    query = URI.encode_www_form(options)
    get(query.empty? ? "/api/v1/work_items" : "/api/v1/work_items?#{query}")
  end

  def answer
    id = required_arg("WORK_ITEM_ID")
    answer = required_arg("ANSWER")
    post("/api/v1/work_items/#{id}/answer", { answer: answer })
  end

  def costs
    options = {}
    OptionParser.new do |parser|
      parser.on("--today") { options[:today] = true }
      parser.on("--work-item WORK_ITEM_ID") { |value| options[:work_item_id] = value }
    end.parse!(@argv)

    if options[:work_item_id]
      id = URI.encode_www_form_component(options[:work_item_id])
      get("/api/v1/costs/work_items/#{id}")
    elsif options[:today]
      get("/api/v1/costs?period=today")
    else
      get("/api/v1/costs")
    end
  end

  def dashboard
    options = {}
    OptionParser.new do |parser|
      parser.on("--queue QUEUE") { |value| options[:queue] = value }
      parser.on("--limit LIMIT") { |value| options[:limit] = value }
      parser.on("--status STATUS") { |value| options[:status] = value }
      parser.on("--watch") { options[:watch] = true }
      parser.on("--refresh SECONDS") { |value| options[:refresh] = value }
    end.parse!(@argv)

    queue_slug = options.fetch(:queue) { raise ArgumentError, "missing queue" }
    if options[:watch]
      watch_dashboard(options.merge(queue: queue_slug))
    else
      @stdout.puts render_dashboard(options.merge(queue: queue_slug))
    end
  end

  def watch_dashboard(options)
    iterations = @env.fetch("STUPIDCLAW_DASHBOARD_ITERATIONS", nil)&.to_i
    refresh_seconds = [options.fetch(:refresh, 5).to_f, 0].max
    count = 0

    loop do
      @stdout.print "\e[H\e[2J"
      @stdout.puts render_dashboard(options)
      count += 1
      break if iterations&.positive? && count >= iterations

      sleep refresh_seconds
    end
  end

  def render_dashboard(options)
    data = Cli::DashboardDataLoader.new(
      client: @client,
      api_url: @base_url,
      queue_slug: options.fetch(:queue),
      limit: options[:limit],
      status: options[:status]
    ).call
    Cli::DashboardRenderer.new(data: data).render
  end

  def get(path)
    print_response(@client.get_json(path))
  end

  def post(path, body)
    print_response(@client.post_json(path, body))
  end

  def print_response(parsed)
    @stdout.puts JSON.pretty_generate(parsed)
  end

  def required_arg(name)
    @argv.shift || raise(ArgumentError, "missing #{name}")
  end
end

exit StupidClawCli.new(ARGV).run if $PROGRAM_NAME == __FILE__

#!/usr/bin/env bash
set -euo pipefail

BASE_URL="${BASE_URL:-${TASKRAIL_BASE_URL:-}}"
if [ -z "${BASE_URL}" ]; then
  echo "usage: BASE_URL=https://service.example.com bin/monitor-prod" >&2
  exit 1
fi

end=$((SECONDS + 120))
while [ $SECONDS -lt $end ]; do
  status=$(curl -sf -o /dev/null -w "%{http_code}" "${BASE_URL}/health" || true)
  if [ "${status}" != "200" ]; then
    echo "health check failed: ${status}" >&2
    exit 1
  fi
  sleep 5
done

echo "monitor-prod passed"

#!/usr/bin/env bash
set -euo pipefail

require_env() {
  local name="$1"
  if [ -z "${!name:-}" ]; then
    echo "missing required env: ${name}" >&2
    exit 1
  fi
}

echo "[1/5] Checking required env vars"
require_env KAMAL_WEB_HOST
require_env KAMAL_APP_HOST
require_env KAMAL_REGISTRY_SERVER
require_env KAMAL_REGISTRY_USERNAME
require_env KAMAL_REGISTRY_PASSWORD

echo "[2/5] Checking Rails master key"
if [ ! -f config/master.key ] && [ -z "${RAILS_MASTER_KEY:-}" ]; then
  echo "missing config/master.key and RAILS_MASTER_KEY is empty" >&2
  exit 1
fi

echo "[3/5] Checking SSH access to ${KAMAL_WEB_HOST}"
ssh -o BatchMode=yes -o ConnectTimeout=5 "${KAMAL_SSH_USER:-$USER}@${KAMAL_WEB_HOST}" 'echo ssh-ok' >/dev/null

echo "[4/5] Checking docker on remote host"
ssh -o BatchMode=yes "${KAMAL_SSH_USER:-$USER}@${KAMAL_WEB_HOST}" 'docker --version' >/dev/null

echo "[5/5] Validating Kamal config"
bin/kamal config >/dev/null

echo "Kamal preflight passed"

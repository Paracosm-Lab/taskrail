<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TaskRail</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <script src="https://cdn.tailwindcss.com"></script>
  <script nonce="<%= content_security_policy_nonce %>">
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            base: '#0f1117',
            mantle: '#181825',
            crust: '#11111b',
            surface0: '#313244',
            surface1: '#45475a',
            surface2: '#585b70',
            overlay0: '#6c7086',
            overlay1: '#7f849c',
            subtext0: '#a6adc8',
            text: '#cdd6f4',
            lavender: '#b4befe',
            blue: '#89b4fa',
            sapphire: '#74c7ec',
            sky: '#89dceb',
            teal: '#94e2d5',
            green: '#a6e3a1',
            yellow: '#f9e2af',
            peach: '#fab387',
            maroon: '#eba0ac',
            red: '#f38ba8',
            mauve: '#cba6f7',
            pink: '#f5c2e7',
            flamingo: '#f2cdcd',
            rosewater: '#f5e0dc',
          }
        }
      }
    }
  </script>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-base text-text min-h-screen font-mono flex flex-col">

  <!-- Top bar -->
  <header class="bg-mantle border-b border-surface0 px-5 py-3 flex items-center flex-shrink-0">
    <%= link_to root_path, class: "flex items-center gap-2 text-mauve font-bold text-sm" do %>
      <span>◈</span>
      <span>TaskRail</span>
    <% end %>
    <div class="ml-auto flex items-center gap-3 text-xs text-overlay0">
      <span>dev console</span>
    </div>
  </header>

  <div class="flex flex-1 overflow-hidden">

    <!-- Left sidebar -->
    <aside class="w-52 flex-shrink-0 bg-mantle border-r border-surface0 flex flex-col overflow-y-auto">

      <div class="px-3 pt-4 pb-2">
        <div class="text-xs font-semibold text-overlay0 uppercase tracking-widest px-2 mb-2">Queues</div>

        <% queues_by_category.each do |category, queues| %>
          <div class="mb-3">
            <div class="text-xs text-overlay1 px-2 py-1 font-medium"><%= category %></div>
            <% queues.each do |q| %>
              <%= link_to queue_path(q.slug),
                    class: "flex items-center gap-2 px-2 py-1 rounded text-xs transition-colors #{request.path == queue_path(q.slug) || request.path == board_queue_path(q.slug) ? 'bg-surface0 text-text' : 'text-overlay0 hover:text-text hover:bg-surface0'}" do %>
                <span class="w-1.5 h-1.5 rounded-full bg-surface1 flex-shrink-0"></span>
                <%= q.name %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="mt-auto border-t border-surface0 px-3 py-3">
        <%= link_to pipes_path,
              class: "flex items-center gap-2 px-2 py-1.5 rounded text-xs transition-colors #{request.path == pipes_path ? 'bg-surface0 text-text' : 'text-overlay0 hover:text-text hover:bg-surface0'}" do %>
          <span>⇢</span>
          Pipes
        <% end %>
      </div>

    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto p-5">
      <% if flash[:notice] %>
        <div class="mb-4 px-3 py-2 bg-surface0 rounded text-green text-sm"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mb-4 px-3 py-2 bg-surface0 rounded text-red text-sm"><%= flash[:alert] %></div>
      <% end %>
      <%= yield %>
    </main>

  </div>
</body>
</html>

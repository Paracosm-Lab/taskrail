<h1 class="text-xl font-bold text-mauve mb-4">Pipes</h1>

<% if @pipes.empty? %>
  <div class="text-overlay0 text-sm text-center py-12">
    No pipes configured. Add YAML files to <code class="text-text">config/pipes/</code> and re-seed.
  </div>
<% else %>
  <div class="bg-mantle rounded overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-overlay0 text-xs border-b border-surface0">
          <th class="text-left px-4 py-3">Name</th>
          <th class="text-left px-4 py-3">From</th>
          <th class="text-left px-4 py-3 text-overlay0">→</th>
          <th class="text-left px-4 py-3">To</th>
          <th class="text-left px-4 py-3">Enabled</th>
          <th class="text-left px-4 py-3">Last Fired</th>
        </tr>
      </thead>
      <tbody>
        <% @pipes.each do |pipe| %>
          <%
            last_fired = TransitionLog
              .where(trigger: "pipe")
              .where("details->>'pipe_slug' = ?", pipe.slug)
              .order(created_at: :desc)
              .first
          %>
          <tr class="border-b border-surface0 hover:bg-surface0 transition-colors">
            <td class="px-4 py-3">
              <div class="text-text font-medium"><%= pipe.name %></div>
              <div class="text-overlay0 text-xs font-mono"><%= pipe.slug %></div>
            </td>
            <td class="px-4 py-3 font-mono text-xs">
              <span class="text-blue"><%= pipe.from_queue.slug %></span>
              <span class="text-overlay0"> / </span>
              <span class="text-text"><%= pipe.from_stage %></span>
            </td>
            <td class="px-4 py-3 text-overlay0">→</td>
            <td class="px-4 py-3 font-mono text-xs">
              <span class="text-blue"><%= pipe.to_queue.slug %></span>
              <% if pipe.to_stage.present? %>
                <span class="text-overlay0"> / </span>
                <span class="text-text"><%= pipe.to_stage %></span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <span class="<%= pipe.enabled? ? 'text-green' : 'text-overlay0' %>">
                <%= pipe.enabled? ? '✓' : '—' %>
              </span>
            </td>
            <td class="px-4 py-3 text-overlay0 text-xs">
              <%= last_fired ? time_ago_in_words(last_fired.created_at) + " ago" : "never" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "net/http"
require "optparse"
require "time"
require "uri"
require_relative "../app/services/cli/task_rail_api_client"
require_relative "../app/services/cli/dashboard_data_loader"
require_relative "../app/services/cli/dashboard_renderer"

class TaskRailCli
  def initialize(argv, env = ENV, stdout = $stdout, stderr = $stderr)
    @argv = argv
    @env = env
    @base_url = env.fetch("TASKRAIL_API_URL", "http://localhost:3000")
    @stdout = stdout
    @stderr = stderr
    @client = Cli::TaskRailApiClient.new(base_url: @base_url)
  end

  def run
    return tui if @argv.empty? || @argv.first.start_with?("-")

    command = @argv.shift

    result = case command
    when "submit" then submit
    when "status" then status
    when "list" then list
    when "answer" then answer
    when "retry" then post("/api/v1/work_items/#{required_arg("WORK_ITEM_ID")}/retry", {})
    when "cancel" then post("/api/v1/work_items/#{required_arg("WORK_ITEM_ID")}/cancel", {})
    when "queues" then get("/api/v1/queues")
    when "stages" then get("/api/v1/queues/#{required_arg("QUEUE")}/stages")
    when "dashboard" then dashboard
    when "costs" then costs
    when "digest" then digest
    when "doctor" then doctor
    else
      @stderr.puts "unknown command: #{command}"
      return 1
    end

    result.is_a?(Integer) ? result : 0
  rescue KeyError, ArgumentError, Cli::TaskRailApiClient::HttpError => error
    @stderr.puts error.message
    1
  end

  private

  def tui
    exec_process("node", File.expand_path("../tui/dist/index.js", __dir__), "--api", @base_url, *@argv)
    0
  end

  def exec_process(*args)
    exec(*args)
  end

  def submit
    options = {}
    OptionParser.new do |parser|
      parser.on("--queue QUEUE") { |value| options[:queue] = value }
      parser.on("--spec SPEC") { |value| options[:spec_url] = value }
      parser.on("--title TITLE") { |value| options[:title] = value }
    end.parse!(@argv)

    post("/api/v1/work_items", {
      queue: options.fetch(:queue),
      spec_url: options.fetch(:spec_url),
      title: options.fetch(:title)
    })
  end

  def status
    id = URI.encode_www_form_component(required_arg("WORK_ITEM_ID"))
    options = {}
    OptionParser.new do |parser|
      parser.on("--traces") { options[:traces] = true }
    end.parse!(@argv)

    query = URI.encode_www_form(options)
    get(query.empty? ? "/api/v1/work_items/#{id}" : "/api/v1/work_items/#{id}?#{query}")
  end

  def list
    options = {}
    OptionParser.new do |parser|
      parser.on("--queue QUEUE") { |value| options[:queue] = value }
      parser.on("--stage STAGE") { |value| options[:stage] = value }
      parser.on("--status STATUS") { |value| options[:status] = value }
      parser.on("--tag KEY=VALUE") do |value|
        key, tag_value = value.split("=", 2)
        raise ArgumentError, "invalid tag filter" if key.nil? || key.empty? || tag_value.nil? || tag_value.empty?

        (options[:tags] ||= {})[key] = tag_value
      end
    end.parse!(@argv)

    query = list_query(options)
    get(query.empty? ? "/api/v1/work_items" : "/api/v1/work_items?#{query}")
  end

  def answer
    id = required_arg("WORK_ITEM_ID")
    answer = required_arg("ANSWER")
    post("/api/v1/work_items/#{id}/answer", { answer: answer })
  end

  def list_query(options)
    pairs = options.reject { |key, _value| key == :tags }.to_a
    options.fetch(:tags, {}).each do |key, value|
      pairs << ["tags[#{key}]", value]
    end
    URI.encode_www_form(pairs)
  end

  def costs
    options = {}
    OptionParser.new do |parser|
      parser.on("--today") { options[:today] = true }
      parser.on("--work-item WORK_ITEM_ID") { |value| options[:work_item_id] = value }
    end.parse!(@argv)

    if options[:work_item_id]
      id = URI.encode_www_form_component(options[:work_item_id])
      get("/api/v1/costs/work_items/#{id}")
    elsif options[:today]
      get("/api/v1/costs?period=today")
    else
      get("/api/v1/costs")
    end
  end

  def digest
    options = { since: "24h", json: false }
    OptionParser.new do |parser|
      parser.on("--since WINDOW") { |value| options[:since] = value }
      parser.on("--json") { options[:json] = true }
    end.parse!(@argv)

    since = URI.encode_www_form_component(options.fetch(:since))
    parsed = @client.get_json("/api/v1/digest?since=#{since}")
    if options[:json]
      @stdout.puts JSON.dump(parsed)
    else
      @stdout.puts render_digest(parsed)
    end
  end

  def doctor
    checks = [
      { path: "/api/v1/queues", expect_json: true, label: "queues endpoint" },
      { path: "/api/v1/costs", expect_json: true, label: "costs endpoint" },
      { path: "/health", expect_json: true, label: "service health endpoint" },
      { path: "/up", expect_json: false, label: "rails health endpoint" }
    ]

    @stdout.puts "TaskRail doctor"
    @stdout.puts "API URL: #{@base_url}"
    @stdout.puts

    failures = 0
    checks.each do |check|
      result = fetch_raw(check.fetch(:path))
      status = result.fetch(:status)
      content_type = result.fetch(:content_type)
      body_preview = result.fetch(:body_preview)
      ok = status.between?(200, 299)
      if check.fetch(:expect_json)
        ok &&= content_type.include?("application/json")
      end

      marker = ok ? "OK" : "FAIL"
      @stdout.puts "[#{marker}] #{check.fetch(:label)} #{check.fetch(:path)}"
      @stdout.puts "  status: #{status}"
      @stdout.puts "  content-type: #{content_type.empty? ? "(none)" : content_type}"
      @stdout.puts "  body: #{body_preview}"
      @stdout.puts
      failures += 1 unless ok
    rescue StandardError => error
      @stdout.puts "[FAIL] #{check.fetch(:label)} #{check.fetch(:path)}"
      @stdout.puts "  error: #{error.class}: #{error.message}"
      @stdout.puts
      failures += 1
    end

    if failures.zero?
      @stdout.puts "Doctor passed."
      0
    else
      @stdout.puts "Doctor found #{failures} issue(s)."
      @stdout.puts "If you see text/html on /api/v1/*, you are likely pointing at a frontend dev server instead of Rails."
      1
    end
  end

  def render_digest(data)
    summary = data.fetch("summary", {})
    costs = data.fetch("costs", {})
    blocked_items = data.fetch("blocked_items", [])
    recent_transitions = data.fetch("recent_transitions", [])

    [
      section("DIGEST (last #{data.fetch("window", "?")})"),
      "  Clusters created:    #{summary.fetch("clusters_created", 0)}",
      "  Runbooks drafted:    #{summary.fetch("runbooks_drafted", 0)}",
      "  Runbooks published:  #{summary.fetch("runbooks_published", 0)}",
      "  Items completed:     #{summary.fetch("items_completed", 0)}",
      "  Items spawned:       #{summary.fetch("items_spawned", 0)}",
      "",
      section("BLOCKED (#{blocked_items.length})"),
      render_blocked_items(blocked_items),
      "",
      section("COSTS"),
      "  #{format_currency(costs.fetch("cents", 0))}  │  ↑#{format_count(costs.fetch("tokens_in", 0))}  ↓#{format_count(costs.fetch("tokens_out", 0))} tokens",
      "",
      section("RECENT"),
      render_recent_transitions(recent_transitions)
    ].flatten.join("\n")
  end

  def section(title)
    "── #{title} #{"─" * 36}"
  end

  def render_blocked_items(items)
    return ["  (none)"] if items.empty?

    items.map do |item|
      [
        "  ##{item.fetch("id")}  #{item.fetch("title")}",
        "       \"#{item.fetch("question", nil)}\"",
        "       → bin/taskrail answer #{item.fetch("id")} \"...\""
      ]
    end
  end

  def render_recent_transitions(transitions)
    return ["  (none)"] if transitions.empty?

    transitions.map do |transition|
      time = Time.iso8601(transition.fetch("at")).utc.strftime("%H:%M")
      "  #{time}  ##{transition.fetch("work_item_id")}  #{transition.fetch("from_stage")} → #{transition.fetch("to_stage")}"
    end
  end

  def format_currency(cents)
    format("$%.2f", cents.to_i / 100.0)
  end

  def format_count(value)
    number = value.to_i
    return number.to_s if number < 1_000

    rounded = number / 100.0
    formatted = format("%.1f", rounded / 10.0).sub(/\.0\z/, "")
    "#{formatted}k"
  end

  def dashboard
    options = {}
    OptionParser.new do |parser|
      parser.on("--queue QUEUE") { |value| options[:queue] = value }
      parser.on("--limit LIMIT") { |value| options[:limit] = value }
      parser.on("--status STATUS") { |value| options[:status] = value }
      parser.on("--watch") { options[:watch] = true }
      parser.on("--refresh SECONDS") { |value| options[:refresh] = value }
    end.parse!(@argv)

    queue_slug = options.fetch(:queue) { raise ArgumentError, "missing queue" }
    if options[:watch]
      watch_dashboard(options.merge(queue: queue_slug))
    else
      @stdout.puts render_dashboard(options.merge(queue: queue_slug))
    end
  end

  def watch_dashboard(options)
    iterations = @env.fetch("TASKRAIL_DASHBOARD_ITERATIONS", nil)&.to_i
    refresh_seconds = [options.fetch(:refresh, 5).to_f, 0].max
    count = 0

    loop do
      @stdout.print "\e[H\e[2J"
      @stdout.puts render_dashboard(options)
      count += 1
      break if iterations&.positive? && count >= iterations

      sleep refresh_seconds
    end
  end

  def render_dashboard(options)
    data = Cli::DashboardDataLoader.new(
      client: @client,
      api_url: @base_url,
      queue_slug: options.fetch(:queue),
      limit: options[:limit],
      status: options[:status]
    ).call
    Cli::DashboardRenderer.new(data: data).render
  end

  def get(path)
    print_response(@client.get_json(path))
  end

  def fetch_raw(path)
    uri = URI.join(@base_url, path)
    response = Net::HTTP.get_response(uri)
    body = response.body.to_s.gsub(/\s+/, " ").strip
    {
      status: response.code.to_i,
      content_type: response["Content-Type"].to_s.downcase,
      body_preview: body.empty? ? "(empty)" : body[0, 120]
    }
  end

  def post(path, body)
    print_response(@client.post_json(path, body))
  end

  def print_response(parsed)
    @stdout.puts JSON.pretty_generate(parsed)
  end

  def required_arg(name)
    @argv.shift || raise(ArgumentError, "missing #{name}")
  end
end

exit TaskRailCli.new(ARGV).run if $PROGRAM_NAME == __FILE__
